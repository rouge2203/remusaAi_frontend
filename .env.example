# Mock data is OFF by default. Set to true only for UI work without backend.
# VITE_USE_MOCK=true

# --- Django API (default dev: Vite proxies /api → http://localhost:8000) ---
# Override full origin in production, e.g. https://api.example.com
# VITE_API_BASE=
#
# Same Wi‑Fi / phone testing: run `npm run dev`, open http://<your-computer-LAN-ip>:5173 on the phone.
# Keep VITE_API_BASE unset so /api stays same-origin and the dev proxy works.

# --- Legacy mock-only keys (not used when VITE_USE_MOCK=false — server uses RemusaAi_backend/.env) ---

# RegCheck Costa Rica
VITE_PLATE_USER=

# 17VIN
VITE_17VIN_USER=
VITE_17VIN_PASSWORD=

# TecDoc fallback (optional)
VITE_RAPIDAPI_KEY=

# Public site URL (no trailing slash). Used at build time for og:image / WhatsApp previews.
# Example: https://app.remusa.com
VITE_SITE_URL=
