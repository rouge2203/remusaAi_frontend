# Mock data is OFF by default. Set to true only for UI work without API keys.
# VITE_USE_MOCK=true

# --- Real APIs (required for plate / VIN / part search) ---

# RegCheck Costa Rica (plate lookup via dev proxy)
VITE_PLATE_USER=

# 17VIN (VIN decode + part search)
VITE_17VIN_USER=
VITE_17VIN_PASSWORD=

# TecDoc fallback (optional). You can use VITE_RAPIDAPI_KEY here, or set RAPIDAPI_KEY
# in the repo root .env — Vite maps root RAPIDAPI_KEY into the client as VITE_RAPIDAPI_KEY.
VITE_RAPIDAPI_KEY=

# Public site URL (no trailing slash). Used at build time for og:image / WhatsApp previews.
# Example: https://app.remusa.com
VITE_SITE_URL=
